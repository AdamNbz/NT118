FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    libpq-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir psycopg2-binary

COPY database/ /app/

# We'll run the script via docker-compose command
CMD ["python", "seed_products.py", "--host", "nt118-postgres", "--user", "postgres", "--password", "postgres", "--database", "nt118"]
